<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LabelStudio.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="LabelStudio.Views.PrintPreviewView"
             x:DataType="vm:PrintPreviewViewModel">

    <Grid ColumnDefinitions="*,320">
        <!-- Canvas Section -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceContainer}">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Margin="0,0,0,32">
                        <TextBlock Text="Print Preview" FontFamily="{StaticResource ManropeFont}" FontWeight="Bold" FontSize="24" Foreground="{StaticResource OnSurface}"/>
                        <TextBlock Text="Populated with real-time ERP data: SKU-20948-X" FontSize="14" Foreground="{StaticResource OnSurfaceVariant}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Label Mockup -->
                    <Border Width="500" Height="333" Background="{StaticResource SurfaceContainerLowest}" CornerRadius="8" BoxShadow="0 4 6 -1 #1A000000, 0 2 4 -1 #0F000000">
                        <Grid RowDefinitions="Auto,*,Auto" Margin="32">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                <Border BorderBrush="#0c000000" BorderThickness="0,0,0,2" Grid.ColumnSpan="2" Margin="0,0,0,-16" Padding="0,0,0,16"/>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PRODUCT COMPONENT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                                    <TextBlock Text="TITANIUM ALLOY STRUT" FontFamily="{StaticResource ManropeFont}" FontWeight="ExtraBold" FontSize="20" Foreground="{StaticResource OnSurface}" Margin="0,4"/>
                                    <TextBlock Text="Grade 5 Annealed / Aerospace Std." FontSize="12" Foreground="{StaticResource OnSurfaceVariant}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="BATCH ID" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2" HorizontalAlignment="Right"/>
                                    <TextBlock Text="#77-B-9920" FontFamily="Consolas,Monospace" FontWeight="SemiBold" FontSize="14" Margin="0,4" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <StackPanel>
                                        <TextBlock Text="WEIGHT" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="1.458 kg" FontSize="18" FontWeight="Medium"/>
                                            <TextBlock Text="±0.001" FontSize="12" Foreground="{StaticResource OnSurfaceVariant}" Margin="4,0,0,0" VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="UNIT PRICE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                                        <TextBlock Text="$284.50" FontSize="18" FontWeight="Medium" Foreground="{StaticResource Primary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource SurfaceContainerLow}" CornerRadius="6" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <!-- Barcode Mock -->
                                        <Border Height="48" Background="{StaticResource OnSurface}" Margin="0,0,0,8" Padding="4">
                                            <StackPanel Orientation="Horizontal" Spacing="1">
                                                <Border Width="4" Background="White"/>
                                                <Border Width="8" Background="White"/>
                                                <Border Width="2" Background="White"/>
                                                <Border Width="6" Background="White"/>
                                                <Border Width="4" Background="White"/>
                                                <Border Width="2" Background="White"/>
                                                <Border Width="8" Background="White"/>
                                                <Border Width="4" Background="White"/>
                                                <Border Width="2" Background="White"/>
                                                <Border Width="6" Background="White"/>
                                                <Border Width="4" Background="White"/>
                                                <Border Width="6" Background="White"/>
                                                <Border Width="2" Background="White"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="5901234123457" FontFamily="Consolas,Monospace" FontSize="10" LetterSpacing="3" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
                                <Border BorderBrush="#0c000000" BorderThickness="0,1,0,0" Grid.ColumnSpan="2" Margin="0,-16,0,16"/>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom">
                                    <StackPanel>
                                        <TextBlock Text="WAREHOUSE" FontSize="8" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                                        <TextBlock Text="SEC-04 / BIN-12" FontSize="10" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="COMPLIANCE" FontSize="8" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                                        <TextBlock Text="ISO 9001:2015" FontSize="10" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="16" Background="#1A000000" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,32,0,0">
                        <Button Background="{StaticResource SurfaceContainerHighest}" Foreground="{StaticResource OnSurface}" CornerRadius="8" Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xe8ff;" FontFamily="{StaticResource MaterialIcons}" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Enlarge" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="{StaticResource SurfaceContainerHighest}" Foreground="{StaticResource OnSurface}" CornerRadius="8" Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xe5d5;" FontFamily="{StaticResource MaterialIcons}" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh Data" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel (Print Settings) -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceContainerHigh}" Padding="24">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0" Text="Print Settings" FontFamily="{StaticResource ManropeFont}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource OnSurface}" Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="TARGET PRINTER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                            <ComboBox ItemsSource="{Binding Printers}" SelectedItem="{Binding SelectedPrinter}" HorizontalAlignment="Stretch" Background="{StaticResource SurfaceContainerLowest}" BorderThickness="0" CornerRadius="6" FontSize="14" FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Border Width="8" Height="8" CornerRadius="4" Background="#10b981"/>
                                <TextBlock Text="Online • Ready to print" FontSize="11" FontWeight="Medium" Foreground="{StaticResource OnSurfaceVariant}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="QUANTITY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button Grid.Column="0" Background="{StaticResource SurfaceContainerLowest}" Width="40" Height="40" CornerRadius="6">
                                    <TextBlock Text="&#xe15b;" FontFamily="{StaticResource MaterialIcons}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <TextBox Grid.Column="1" Text="12" TextAlignment="Center" FontWeight="Bold" FontSize="14" Background="{StaticResource SurfaceContainerLowest}" BorderThickness="0" Margin="8,0" CornerRadius="6" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="2" Background="{StaticResource SurfaceContainerLowest}" Width="40" Height="40" CornerRadius="6">
                                    <TextBlock Text="&#xe145;" FontFamily="{StaticResource MaterialIcons}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="ORIENTATION" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowest}" BorderBrush="{StaticResource Primary}" BorderThickness="2" CornerRadius="6" Padding="12" Margin="0,0,4,0">
                                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                                        <TextBlock Text="&#xe3f7;" FontFamily="{StaticResource MaterialIcons}" Foreground="{StaticResource Primary}" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Landscape" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{StaticResource SurfaceContainerLow}" BorderBrush="Transparent" BorderThickness="2" CornerRadius="6" Padding="12" Margin="4,0,0,0">
                                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                                        <TextBlock Text="&#xe3f8;" FontFamily="{StaticResource MaterialIcons}" Foreground="{StaticResource OnSurfaceVariant}" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Portrait" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceVariant}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="MARGIN ADJUSTMENT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2"/>
                                <TextBlock Grid.Column="1" Text="2.5mm" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Primary}"/>
                            </Grid>
                            <Slider Value="2.5" Minimum="0" Maximum="10" Foreground="{StaticResource Primary}"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="0mm" FontSize="9" FontWeight="Medium" Foreground="{StaticResource OnSurfaceVariant}"/>
                                <TextBlock Grid.Column="1" Text="10mm" FontSize="9" FontWeight="Medium" Foreground="{StaticResource OnSurfaceVariant}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="12" Margin="0,16,0,0">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Mirror horizontally" FontSize="12" FontWeight="Medium"/>
                                <ToggleSwitch Grid.Column="1" IsChecked="False"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="High-density ink (300dpi)" FontSize="12" FontWeight="Medium"/>
                                <ToggleSwitch Grid.Column="1" IsChecked="True"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Spacing="12" Margin="0,16,0,0">
                    <Border Background="#e6f0fa" BorderBrush="#ccdbf2" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="&#xe88e;" FontFamily="{StaticResource MaterialIcons}" Foreground="{StaticResource Primary}"/>
                            <TextBlock Text="Total of 12 labels will use approx. 1.8m of ribbon." FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Primary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Button Background="{StaticResource Primary}" Foreground="{StaticResource OnPrimary}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="16" CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="&#xe8ad;" FontFamily="{StaticResource MaterialIcons}" VerticalAlignment="Center"/>
                            <TextBlock Text="Send to Printer" FontFamily="{StaticResource ManropeFont}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Auto-saving project before output..." FontSize="10" FontWeight="Medium" Foreground="{StaticResource OnSurfaceVariant}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</UserControl>
