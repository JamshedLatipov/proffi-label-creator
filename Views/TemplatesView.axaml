<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LabelStudio.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="LabelStudio.Views.TemplatesView"
             x:DataType="vm:TemplatesViewModel">

    <Grid RowDefinitions="Auto,*" Margin="32">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="Projects" FontSize="12" Foreground="{StaticResource OnSurfaceVariant}"/>
                <TextBlock Text="&#xe5cc;" FontFamily="{StaticResource MaterialIcons}" FontSize="14" Foreground="{StaticResource OnSurfaceVariant}" VerticalAlignment="Center"/>
                <TextBlock Text="Standard Templates" FontSize="12" FontWeight="Medium" Foreground="{StaticResource OnSurface}"/>
            </StackPanel>
            <TextBlock Text="Label Templates" FontFamily="{StaticResource ManropeFont}" FontWeight="ExtraBold" FontSize="32" Foreground="{StaticResource OnSurface}"/>
            <TextBlock Text="Manage and deploy technical drafting specifications." FontSize="14" Foreground="{StaticResource OnSurfaceVariant}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Grid -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Templates}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.DataTemplates>
                    <DataTemplate x:DataType="vm:TemplateItemViewModel">
                        <Border Background="{StaticResource SurfaceContainerLowest}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Width="280" Margin="0,0,24,24">
                            <Grid RowDefinitions="Auto,*">
                                <!-- Label preview -->
                                <Border Grid.Row="0" Height="210" Background="{StaticResource SurfaceContainerLow}"
                                        CornerRadius="12,12,0,0" Margin="4" ClipToBounds="True">
                                    <Viewbox Stretch="Uniform" Margin="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Border BoxShadow="0 2 8 0 #22000000" x:CompileBindings="False">
                                            <Canvas x:CompileBindings="False"
                                                    Width="{Binding Preview.CanvasWidth}"
                                                    Height="{Binding Preview.CanvasHeight}"
                                                    Background="White"
                                                    ClipToBounds="True">
                                                <ItemsControl Canvas.Left="0" Canvas.Top="0"
                                                              Width="{Binding Preview.CanvasWidth}"
                                                              Height="{Binding Preview.CanvasHeight}"
                                                              Padding="0"
                                                              ItemsSource="{Binding Preview.Elements}"
                                                              x:CompileBindings="False">
                                                    <ItemsControl.ItemContainerTheme>
                                                        <ControlTheme TargetType="ContentPresenter">
                                                            <Setter Property="Margin"      Value="0"/>
                                                            <Setter Property="Padding"     Value="0"/>
                                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                            <Setter Property="Canvas.Top"  Value="{Binding Top}"/>
                                                        </ControlTheme>
                                                    </ItemsControl.ItemContainerTheme>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:CompileBindings="False">
                                                            <Border Width="{Binding Width}" Height="{Binding Height}"
                                                                    BorderThickness="0" CornerRadius="0">
                                                                <Grid>
                                                                    <TextBlock IsVisible="{Binding Kind, Converter={x:Static vm:ElementKindConverter.IsText}}"
                                                                               Text="{Binding Content}"
                                                                               FontFamily="{Binding FontFamily}"
                                                                               FontSize="{Binding FontSize}"
                                                                               FontWeight="{Binding Bold, Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                                                                               Background="{Binding TextBackgroundBrush}"
                                                                               TextWrapping="Wrap" Margin="3,2"/>
                                                                    <Border IsVisible="{Binding Kind, Converter={x:Static vm:ElementKindConverter.IsDynamic}}"
                                                                            Background="#e6f0fa" CornerRadius="2" Margin="2">
                                                                        <TextBlock Text="{Binding DisplayContent}"
                                                                                   FontFamily="Consolas,Monospace"
                                                                                   FontSize="{Binding FontSize}"
                                                                                   Foreground="{StaticResource Primary}"
                                                                                   Margin="3,1" TextWrapping="Wrap"/>
                                                                    </Border>
                                                                    <Image IsVisible="{Binding Kind, Converter={x:Static vm:ElementKindConverter.IsBarcode}}"
                                                                           Source="{Binding BarcodeSource}" Stretch="Fill"/>
                                                                    <Image IsVisible="{Binding Kind, Converter={x:Static vm:ElementKindConverter.IsQr}}"
                                                                           Source="{Binding QrSource}" Stretch="Uniform"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Border IsVisible="{Binding Kind, Converter={x:Static vm:ElementKindConverter.IsRect}}"
                                                                            BorderBrush="{StaticResource OnSurface}"
                                                                            BorderThickness="2" Margin="2"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Canvas>
                                        </Border>
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="20">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontFamily="{StaticResource ManropeFont}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource OnSurface}" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1" Background="{StaticResource SurfaceContainerHigh}" CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariant}" />
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource OnSurfaceVariant}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="&#xe41c;" FontFamily="{StaticResource MaterialIcons}" FontSize="14" Foreground="{StaticResource OnSurfaceVariant}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Size}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource OnSurface}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding OpenCommand}"
                                                Background="{StaticResource Primary}"
                                                Foreground="{StaticResource OnPrimary}"
                                                CornerRadius="6"
                                                Padding="12,6"
                                                FontSize="11"
                                                FontWeight="SemiBold">
                                            USE
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

</UserControl>
