<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LabelStudio.ViewModels"
             xmlns:models="using:LabelStudio.Models"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="900"
             x:Class="LabelStudio.Views.NewProjectView"
             x:DataType="vm:NewProjectViewModel">

    <ScrollViewer>
        <Grid RowDefinitions="Auto,*" Margin="32">

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <TextBlock Text="Projects" FontSize="12" Foreground="{StaticResource OnSurfaceVariant}"/>
                    <TextBlock Text="&#xe5cc;" FontFamily="{StaticResource MaterialIcons}" FontSize="14"
                               Foreground="{StaticResource OnSurfaceVariant}" VerticalAlignment="Center"/>
                    <TextBlock Text="New Project" FontSize="12" FontWeight="Medium" Foreground="{StaticResource OnSurface}"/>
                </StackPanel>
                <TextBlock Text="New Project" FontFamily="{StaticResource ManropeFont}" FontWeight="ExtraBold"
                           FontSize="32" Foreground="{StaticResource OnSurface}"/>
                <TextBlock Text="Configure your label project settings before opening the editor."
                           FontSize="14" Foreground="{StaticResource OnSurfaceVariant}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form Card -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceContainerLowest}"
                    BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1"
                    CornerRadius="16" MaxWidth="680" HorizontalAlignment="Left" Padding="40">
                <StackPanel Spacing="0">

                    <!-- ── 1. PROJECT DETAILS ──────────────────────────────── -->
                    <TextBlock Text="1. PROJECT DETAILS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2" Margin="0,0,0,20"/>

                    <StackPanel Spacing="16" Margin="0,0,0,36">
                        <!-- Name -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="PROJECT NAME" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="1"/>
                                <TextBlock Text="*" FontSize="10" FontWeight="Bold" Foreground="#e53e3e"/>
                            </StackPanel>
                            <TextBox Text="{Binding ProjectName}" Watermark="e.g. Titanium Strut Label v2"
                                     Background="{StaticResource SurfaceContainerLow}"
                                     BorderBrush="{StaticResource OutlineVariant}" CornerRadius="8"
                                     FontSize="14" Padding="12,10"/>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="1"/>
                            <TextBox Text="{Binding Description}"
                                     Watermark="Optional project notes…"
                                     Background="{StaticResource SurfaceContainerLow}"
                                     BorderBrush="{StaticResource OutlineVariant}" CornerRadius="8"
                                     FontSize="13" Padding="12,10" Height="72"
                                     AcceptsReturn="True" TextWrapping="Wrap"/>
                        </StackPanel>


                    </StackPanel>

                    <!-- Divider -->
                    <Border BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0" Margin="0,0,0,32"/>

                    <!-- ── 2. LABEL FORMAT ──────────────────────────────────── -->
                    <TextBlock Text="2. LABEL FORMAT" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2" Margin="0,0,0,20"/>

                    <StackPanel Spacing="20" Margin="0,0,0,36">

                        <!-- Size Presets -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="SIZE PRESET" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="1"/>
                            <ItemsControl ItemsSource="{Binding Presets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Button Content="{Binding}"
                                                Command="{Binding $parent[UserControl].DataContext.SelectPresetCommand}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,8,8"
                                                Padding="16,8" CornerRadius="20"
                                                FontSize="12" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- W × H fields -->
                        <Grid ColumnDefinitions="*,16,*,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="WIDTH (mm)"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceVariant}" Margin="4,0,0,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="HEIGHT (mm)"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceVariant}" Margin="4,0,0,6"/>

                            <TextBox Grid.Row="1" Grid.Column="0"
                                     Text="{Binding LabelWidth}"
                                     IsEnabled="{Binding IsCustomSize}"
                                     FontFamily="Consolas,Monospace" FontSize="14"
                                     Background="{StaticResource SurfaceContainerLow}"
                                     BorderBrush="{StaticResource OutlineVariant}"
                                     CornerRadius="8" Padding="12,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="1" Text="×"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontSize="18" Foreground="{StaticResource OnSurfaceVariant}"/>

                            <TextBox Grid.Row="1" Grid.Column="2"
                                     Text="{Binding LabelHeight}"
                                     IsEnabled="{Binding IsCustomSize}"
                                     FontFamily="Consolas,Monospace" FontSize="14"
                                     Background="{StaticResource SurfaceContainerLow}"
                                     BorderBrush="{StaticResource OutlineVariant}"
                                     CornerRadius="8" Padding="12,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="3"
                                       Text="mm" VerticalAlignment="Center"
                                       Margin="10,0,0,0" FontSize="13"
                                       Foreground="{StaticResource OnSurfaceVariant}"/>
                        </Grid>

                        <!-- Orientation -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="ORIENTATION" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="1"/>
                            <Grid ColumnDefinitions="*,16,*">
                                <!-- Portrait -->
                                <Border Grid.Column="0" CornerRadius="10" Padding="18,14"
                                        BorderThickness="2" Cursor="Hand">
                                    <Button Background="Transparent" BorderThickness="0"
                                            Command="{Binding SetPortraitCommand}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                                            <TextBlock Text="&#xe3f8;" FontFamily="{StaticResource MaterialIcons}"
                                                       FontSize="28" HorizontalAlignment="Center"
                                                       Foreground="{StaticResource Primary}"/>
                                            <TextBlock Text="Portrait" FontSize="12" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="H &gt; W" FontSize="10"
                                                       Foreground="{StaticResource OnSurfaceVariant}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                                <!-- Landscape -->
                                <Border Grid.Column="2" CornerRadius="10" Padding="18,14"
                                        BorderThickness="2" Cursor="Hand">
                                    <Button Background="Transparent" BorderThickness="0"
                                            Command="{Binding SetLandscapeCommand}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                                            <TextBlock Text="&#xe3f7;" FontFamily="{StaticResource MaterialIcons}"
                                                       FontSize="28" HorizontalAlignment="Center"
                                                       Foreground="{StaticResource OnSurfaceVariant}"/>
                                            <TextBlock Text="Landscape" FontSize="12" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="W &gt; H" FontSize="10"
                                                       Foreground="{StaticResource OnSurfaceVariant}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0" Margin="0,0,0,32"/>

                    <!-- ── 3. PRINTER PROFILE ──────────────────────────────── -->
                    <TextBlock Text="3. PRINTER PROFILE" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="2" Margin="0,0,0,20"/>

                    <StackPanel Spacing="12" Margin="0,0,0,36">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="PROFILE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}" LetterSpacing="1"/>
                                <TextBlock Text="*" FontSize="10" FontWeight="Bold" Foreground="#e53e3e"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding PrinterProfiles}"
                                      SelectedItem="{Binding SelectedPrinterProfile}"
                                      HorizontalAlignment="Stretch"
                                      Background="{StaticResource SurfaceContainerLow}"
                                      BorderBrush="{StaticResource OutlineVariant}"
                                      CornerRadius="8" FontSize="13" Padding="12,10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:PrinterProfile">
                                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Profile summary card -->
                        <Border Background="{StaticResource SurfaceContainerLow}"
                                BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1"
                                CornerRadius="8" Padding="16,12"
                                IsVisible="{Binding SelectedPrinterProfile, Converter={x:Static vm:NullToBoolConverter.Instance}}">
                            <Grid ColumnDefinitions="*,*,*,*">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="PRINTER" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}"/>
                                    <TextBlock Text="{Binding SelectedPrinterProfile.PrinterName}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource OnSurface}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="DPI" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}"/>
                                    <TextBlock Text="{Binding SelectedPrinterProfile.Dpi}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Consolas,Monospace"
                                               Foreground="{StaticResource OnSurface}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="MATERIAL" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}"/>
                                    <TextBlock Text="{Binding SelectedPrinterProfile.Material}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource OnSurface}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Text="COLOR" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource OnSurface}"
                                               Text="{Binding SelectedPrinterProfile.IsMonochrome, Converter={x:Static vm:BoolToStringConverter.MonoColor}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Divider -->
                    <Border BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0" Margin="0,0,0,32"/>

                    <!-- ── 4. ACTIONS ──────────────────────────────────────── -->
                    <Grid ColumnDefinitions="*,Auto,16,Auto">
                        <!-- validation hint -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#xe88e;" FontFamily="{StaticResource MaterialIcons}"
                                       FontSize="16" Foreground="{StaticResource OnSurfaceVariant}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Fields marked * are required"
                                       FontSize="11" Foreground="{StaticResource OnSurfaceVariant}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding CancelCommand}"
                                Background="{StaticResource SurfaceContainerHighest}"
                                Foreground="{StaticResource OnSurface}"
                                CornerRadius="10" Padding="24,12">
                            <TextBlock Text="Cancel" FontWeight="SemiBold" FontSize="13"/>
                        </Button>

                        <Button Grid.Column="3"
                                Command="{Binding CreateProjectCommand}"
                                Background="{StaticResource Primary}"
                                Foreground="{StaticResource OnPrimary}"
                                CornerRadius="10" Padding="24,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Create Project" FontFamily="{StaticResource ManropeFont}"
                                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="&#xe5c8;" FontFamily="{StaticResource MaterialIcons}"
                                           FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
